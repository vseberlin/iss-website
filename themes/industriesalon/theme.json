{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1720px",
      "wideSize": "1720px"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "units": [
        "px",
        "rem",
        "%",
        "vw",
        "vh"
      ],
      "spacingSizes": [
        {
          "name": "XS",
          "slug": "xs",
          "size": "0.5rem"
        },
        {
          "name": "S",
          "slug": "s",
          "size": "0.75rem"
        },
        {
          "name": "M",
          "slug": "m",
          "size": "1rem"
        },
        {
          "name": "L",
          "slug": "l",
          "size": "1.5rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "2rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "3rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "4rem"
        },
        {
          "name": "4XL",
          "slug": "4xl",
          "size": "6rem"
        }
      ]
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "custom": true,
      "palette": [
        {
          "name": "Scarlet Red",
          "slug": "scarlet-red",
          "color": "#e81d25"
        },
        {
          "name": "Vaporous White",
          "slug": "vaporous-white",
          "color": "#f9f9fa"
        },
        {
          "name": "Eerie Black",
          "slug": "eerie-black",
          "color": "#1e1e1e"
        },
        {
          "name": "Cerebral Grey",
          "slug": "cerebral-grey",
          "color": "#c0b8b5"
        },
        {
          "name": "Turtle Green",
          "slug": "turtle-green",
          "color": "#579e7d"
        },
        {
          "name": "Pale Rock Blue",
          "slug": "pale-rock-blue",
          "color": "#869fba"
        },
        {
          "name": "Sunrise Yellow",
          "slug": "sunrise-yellow",
          "color": "#ebbc1e"
        },
        {
          "name": "Russet Brown",
          "slug": "russet-brown",
          "color": "#753a18"
        }
      ],
      "gradients": []
    },
    "typography": {
      "customFontSize": true,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "name": "IBM Plex Sans",
          "slug": "plex",
          "fontFamily": "\"IBM Plex Sans\", system-ui, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Medium",
          "slug": "medium",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "1.5rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "2rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "2.75rem"
        },
        {
          "name": "4XL",
          "slug": "4xl",
          "size": "4rem"
        }
      ],
      "lineHeight": true
    },
    "border": {
      "customRadius": true,
      "customWidth": true
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--vaporous-white)",
      "text": "var(--wp--preset--color--eerie-black)"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--plex)",
      "fontSize": "1rem",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--plex)",
          "fontWeight": "700",
          "lineHeight": "1.15"
        },
        "color": {
          "text": "var(--wp--preset--color--eerie-black)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "clamp(2.5rem, 5vw, 4.5rem)",
          "fontWeight": "700",
          "lineHeight": "1.05"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "clamp(2rem, 3.8vw, 3.25rem)",
          "fontWeight": "700",
          "lineHeight": "1.08"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "clamp(1.5rem, 2.8vw, 2.25rem)",
          "fontWeight": "600",
          "lineHeight": "1.15"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "clamp(1.25rem, 2vw, 1.75rem)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "1.125rem",
          "fontWeight": "600",
          "lineHeight": "1.25"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "1rem",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--scarlet-red)"
        }
      },
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--scarlet-red)",
          "text": "var(--wp--preset--color--vaporous-white)"
        },
        "spacing": {
          "padding": {
            "top": "0.85rem",
            "right": "1.25rem",
            "bottom": "0.85rem",
            "left": "1.25rem"
          }
        },
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--plex)",
          "fontWeight": "600",
          "fontSize": "1rem",
          "lineHeight": "1"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/post-title": {
        "typography": {
          "fontWeight": "700",
          "lineHeight": "1.08"
        }
      },
      "core/paragraph": {
        "typography": {
          "fontWeight": "400",
          "lineHeight": "1.6"
        }
      },
      "core/list": {
        "typography": {
          "fontWeight": "400",
          "lineHeight": "1.6"
        }
      },
      "core/quote": {
        "typography": {
          "fontWeight": "400",
          "lineHeight": "1.5"
        },
        "border": {
          "left": {
            "color": "var(--wp--preset--color--scarlet-red)",
            "width": "4px"
          }
        },
        "spacing": {
          "padding": {
            "left": "1rem"
          }
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--cerebral-grey)"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "1.5rem"
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "1.5rem"
        }
      },
      "core/buttons": {
        "spacing": {
          "blockGap": "1rem"
        }
      }
    }
  }
}