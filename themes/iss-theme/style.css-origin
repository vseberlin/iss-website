/*
Theme Name: ISS Theme
Theme URI: https://example.com/
Description: Current ISS block-theme stylesheet. Merged from the outgoing theme base layer and the new tours module.
Author: OpenAI
Version: 1.1.1
Text Domain: iss-theme
*/

/* =====================================================================
   ISS THEME STYLESHEET
   ---------------------------------------------------------------------
   WHAT THIS FILE IS
   - This is the stylesheet for the current block theme.
   - It keeps the new, cleaner tours module as the primary component layer.
   - It reintroduces only the necessary base pieces from the outgoing theme:
     tokens, basic layout shell, header, hero, footer, and reusable buttons.

   WHAT THIS FILE IS NOT
   - It is not a dump of the old theme CSS.
   - It does not globally restyle Gutenberg blocks across the whole site.
   - It avoids generic selectors such as broad .wp-block-group overrides.

   HOW TO USE IT
   - Load this file as the main theme stylesheet (style.css).
   - The HTML templates already provide the structural hooks:
       .iss-header
       .iss-hero-stack
       .iss-hero
       .iss-page-main
       .iss-footer
   - The tours page / section uses the namespaced .iss-tour-* classes.
   ===================================================================== */

/* =====================================================================
   1. DESIGN TOKENS
   ===================================================================== */

:root {
  --site-header-height: 112px;

  --site-color-bg: var(--wp--preset--color--bg);
  --site-color-surface: var(--wp--preset--color--bg-soft);
  --site-color-text: var(--wp--preset--color--text);
  --site-color-text-muted: var(--wp--preset--color--text-muted);
  --site-color-text-inverse: var(--wp--preset--color--bg);
  --site-color-accent: var(--wp--preset--color--accent);
  --site-color-accent-hover: var(--wp--preset--color--accent-hover);
  --site-color-accent-2: var(--wp--preset--color--steel);
  --site-color-border: color-mix(in srgb, var(--site-color-text) 14%, transparent);
  --site-color-overlay: color-mix(in srgb, var(--site-color-text) 42%, transparent);

  --site-font-body: var(--wp--preset--font-family--plex);
  --site-font-heading: var(--wp--preset--font-family--plex);

  --site-space-1: 0.5rem;
  --site-space-2: 0.75rem;
  --site-space-3: 1rem;
  --site-space-4: 1.5rem;
  --site-space-5: 2rem;
  --site-space-6: 3rem;
  --site-space-7: 4rem;
  --site-space-8: 6rem;

  --site-radius-s: 0.75rem;
  --site-radius-m: 1.25rem;
  --site-radius-l: 1.75rem;
  --site-shadow-card: 0 8px 28px rgba(0, 0, 0, 0.08);

  --site-width-wide: 1280px;
}

@media (max-width: 767px) {
  :root {
    --site-header-height: 84px;
  }
}

/* =====================================================================
   2. BASE RESET AND SITE SHELL
   ===================================================================== */

*,
*::before,
*::after {
  box-sizing: border-box;
}

html,
body {
  height: 100%;
}

body {
  min-height: 100vh;
  max-width: 100%;
  overflow-x: hidden;
  background: var(--site-color-bg);
  color: var(--site-color-text);
  font-family: var(--site-font-body);
}

.wp-site-blocks {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  max-width: 100%;
  overflow-x: hidden;
}

.wp-site-blocks > main {
  flex: 1 0 auto;
}

a {
  color: var(--site-color-accent);
  text-decoration-thickness: 0.08em;
}
a:hover,
a:focus {
  color: var(--site-color-accent-hover);
}

/* =====================================================================
   3. UTILITY CLASSES
   ===================================================================== */

.container-1280 {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 0 auto;
}

.section-divider--fade {
  height: 1px;
  margin: 3rem auto;
  max-width: var(--site-width-wide);
  background: linear-gradient(to right, transparent, var(--site-color-border), transparent);
}

.tour-ratio {
  position: relative;
  width: 100%;
  padding-top: 56.25%;
}

.tour-ratio iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

/* =====================================================================
   4. REUSABLE BUTTONS
   ===================================================================== */

.iss-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 2.5rem;
  padding: 0.72rem 1.2rem;
  border: 1px solid var(--site-color-accent);
  border-radius: 999px;
  background: var(--site-color-accent);
  color: var(--site-color-text-inverse);
  text-decoration: none;
  line-height: 1.2;
}

.iss-button:hover,
.iss-button:focus {
  background: var(--site-color-accent-hover);
  border-color: var(--site-color-accent-hover);
  color: var(--site-color-text-inverse);
}

.iss-button--secondary {
  background: transparent;
  color: var(--site-color-text);
  border-color: var(--site-color-border);
}

.iss-button--secondary:hover,
.iss-button--secondary:focus {
  background: var(--site-color-surface);
  color: var(--site-color-text);
  border-color: var(--site-color-text);
}

/* =====================================================================
   5. HEADER
   ===================================================================== */

.iss-header {
  position: relative;
  width: 100%;
  z-index: 30;
}

.iss-header__inner.is-layout-flex,
.iss-header__inner {
  display: grid !important;
  grid-template-columns: auto 1fr;
  align-items: center;
  column-gap: clamp(1rem, 2vw, 2.5rem);
  width: min(var(--site-width-wide), calc(100% - 3rem));
  margin: 0 auto;
  min-height: var(--site-header-height);
}

@media (max-width: 767px) {
  .iss-header__inner.is-layout-flex,
  .iss-header__inner {
    width: min(calc(100% - 1.5rem), var(--site-width-wide));
    padding-top: 0.35rem;
  }
}

.iss-header__brand img,
.iss-header__brand .custom-logo {
  display: block;
  width: auto;
  max-height: 44px;
  justify-self: start;
}

.iss-header__nav {
  justify-self: start;
  min-width: 0;
}

.iss-header__nav .wp-block-navigation__container {
  gap: 0.8rem;
}

.iss-header__nav a,
.iss-header__nav .wp-block-navigation-item__content,
.iss-header__nav .wp-block-pages-list__item__link {
  text-decoration: none;
}

.iss-header--hero {
  position: absolute;
  inset: 0 auto auto 0;
  width: 100%;
  max-width: 100%;
  background: transparent;
  z-index: 50;
}

body.admin-bar .iss-header--hero {
  top: 32px;
}

@media (max-width: 782px) {
  body.admin-bar .iss-header--hero {
    top: 46px;
  }
}

.iss-header--hero::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(
    to bottom,
    rgba(12, 14, 18, 0.82) 0%,
    rgba(12, 14, 18, 0.48) 38%,
    rgba(12, 14, 18, 0.18) 68%,
    rgba(30, 26, 30, 0) 100%
  );
}

.iss-header--hero .iss-header__inner {
  position: relative;
  z-index: 1;
}

.iss-header--hero .iss-header__nav a,
.iss-header--hero .iss-header__nav .wp-block-navigation-item__content,
.iss-header--hero .iss-header__nav .wp-block-pages-list__item__link,
.iss-header--hero .wp-block-site-title a {
  color: #fff !important;
}

.iss-header--hero .iss-header__nav a:hover,
.iss-header--hero .iss-header__nav .wp-block-navigation-item__content:hover,
.iss-header--hero .iss-header__nav .wp-block-pages-list__item__link:hover,
.iss-header--hero .wp-block-site-title a:hover {
  color: rgba(255, 255, 255, 0.82) !important;
}

.iss-header--hero .wp-block-navigation__responsive-container-open,
.iss-header--hero .wp-block-navigation__responsive-container-open svg {
  color: #fff !important;
  fill: #fff !important;
}

@media (max-width: 767px) {
  .iss-header--hero .iss-header__brand img,
  .iss-header--hero .iss-header__brand .custom-logo {
    max-height: 36px;
  }
}

/* =====================================================================
   6. HERO STACK / HERO COVER
   ===================================================================== */

.iss-hero-stack > .iss-hero {
  margin-block-start: 0 !important;
  margin-top: 0 !important;
}

.iss-hero {
  position: relative;
  min-height: 60vh;
  overflow: hidden;
  max-width: 100%;
}

.iss-hero > img,
.iss-hero > .wp-block-cover__image-background {
  position: absolute !important;
  inset: 0;
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
}

.iss-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background: linear-gradient(
    to bottom,
    rgba(30, 26, 30, 0.18) 0%,
    rgba(30, 26, 30, 0.14) 35%,
    rgba(30, 26, 30, 0.30) 100%
  );
}

.iss-hero > .wp-block-cover__inner-container {
  position: relative;
  z-index: 2;
  min-height: 60vh;
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 100%;
  justify-content: flex-start;
}

.iss-hero__inner {
  width: min(calc(100% - 1.5rem), var(--site-width-wide));
  margin: 0 auto;
  padding: calc(var(--site-header-height) + 1.5rem) 0 2rem;
  color: #fff;
}

.iss-hero__copy {
  position: relative;
  max-width: 100%;
  margin-left: 0;
}

.iss-hero__copy::before {
  content: "";
  position: absolute;
  inset: -2rem;
  z-index: 0;
  pointer-events: none;
  background: radial-gradient(
    ellipse at center,
    rgba(30, 26, 30, 0.18) 0%,
    rgba(30, 26, 30, 0.10) 45%,
    rgba(30, 26, 30, 0) 100%
  );
  filter: blur(20px);
}

.iss-hero__copy > * {
  position: relative;
  z-index: 1;
}

.iss-hero__inner :is(h1, h2, h3, h4, p, li) {
  color: #fff;
  max-width: 100%;
  overflow-wrap: anywhere;
  word-break: break-word;
  hyphens: auto;
}

.iss-hero__inner .wp-block-button__link,
.iss-hero__inner .iss-button {
  background: var(--site-color-accent);
  color: #fff;
}

.iss-hero__inner .wp-block-button__link:hover,
.iss-hero__inner .iss-button:hover {
  background: var(--site-color-accent-hover);
  color: #fff;
}

@media (max-width: 767px) {
  .iss-hero,
  .iss-hero > .wp-block-cover__inner-container {
    min-height: 60vh;
  }

  .iss-hero__inner {
    width: min(calc(100% - 1.5rem), var(--site-width-wide));
    padding: calc(var(--site-header-height) + 1rem) 0 1.5rem;
  }

  .iss-hero__copy {
    max-width: 100%;
  }
}

/* =====================================================================
   7. MAIN CONTENT AREA
   ===================================================================== */

.iss-page-main {
  width: 100%;
}

/* =====================================================================
   8. FOOTER
   ===================================================================== */

.iss-footer {
  background: var(--site-color-bg);
  border-top: 1px solid var(--site-color-border);
}

.iss-footer__inner {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 0 auto;
  padding: var(--site-space-7) 0;
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr;
  gap: var(--site-space-6);
  align-items: start;
}

.iss-footer__brand {
  display: grid;
  gap: var(--site-space-3);
}

.iss-footer__tagline {
  max-width: 22ch;
  margin: 0;
  opacity: 0.9;
}

.iss-footer__heading {
  margin: 0 0 0.5rem;
  font-size: 0.98rem;
  text-transform: none;
  letter-spacing: 0.02em;
}

.iss-footer__contact p {
  margin: 0;
}

.iss-footer__nav a {
  color: var(--site-color-text);
  text-decoration: none;
}

.iss-footer__nav a:hover {
  color: var(--site-color-accent);
}

@media (max-width: 760px) {
  .iss-footer__inner {
    width: min(calc(100% - 1.5rem), var(--site-width-wide));
    grid-template-columns: 1fr;
    gap: var(--site-space-5);
  }

  .iss-footer__tagline {
    max-width: 100%;
  }
}

/* =====================================================================
   9. TOURS SECTION
   ===================================================================== */

.iss-tour-section {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 0 auto;
  padding: 3rem 0 4rem;
}

.iss-tour-section__intro {
  max-width: 78ch;
  margin: 0 auto 3rem;
}

.iss-tour-section__intro > *:first-child {
  margin-top: 0;
}

.iss-tour-section__intro > *:last-child {
  margin-bottom: 0;
}

.iss-tour-section__headline {
  margin: 0 0 0.75rem;
  color: var(--site-color-text);
  font-size: clamp(1.9rem, 2.4vw, 2.8rem);
  line-height: 1.08;
  text-align: center;
  text-wrap: balance;
}

.iss-tour-section__lead {
  margin: 0;
  color: var(--site-color-text-muted);
  font-size: 1.04rem;
  line-height: 1.7;
}

.iss-tour-section__divider {
  height: 1px;
  margin: 0 0 3rem;
  background: linear-gradient(to right, transparent, var(--site-color-border), transparent);
}

/* ---------------------------------------------------------------------
   FEATURED TOUR CARD
   --------------------------------------------------------------------- */

.iss-tour-featured {
  margin-bottom: 3rem;
}

.iss-tour-featured .wp-block-post-template > li > .iss-tour-card--featured,
.iss-tour-card--featured {
  display: grid !important;
  grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr) !important;
  align-items: stretch;
  min-height: 30rem;
  overflow: hidden;
  border: 0;
  border-radius: 0;
  background: var(--site-color-accent-2);
  box-shadow: none;
}

.iss-tour-card--featured > .iss-tour-card__body {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1rem;
  padding: clamp(2rem, 3vw, 3.5rem);
  background: var(--site-color-accent-2);
  color: var(--site-color-text-inverse);
  min-width: 0;
}

.iss-tour-card--featured .iss-tour-card__eyebrow {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  min-height: 2rem;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  background: transparent;
  color: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(255, 255, 255, 0.45);
  font-size: 0.82rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0.02em;
  text-transform: none;
}

.iss-tour-card--featured .iss-tour-card__title,
.iss-tour-card--featured .wp-block-post-title {
  margin: 0 !important;
  color: var(--site-color-text-inverse) !important;
  font-size: clamp(1.8rem, 2vw, 2.5rem);
  line-height: 1.06;
  text-wrap: balance;
}

.iss-tour-card--featured .iss-tour-card__title a,
.iss-tour-card--featured .wp-block-post-title a {
  color: inherit !important;
  text-decoration: none;
}

.iss-tour-card--featured .iss-tour-card__title a:hover,
.iss-tour-card--featured .wp-block-post-title a:hover {
  color: rgba(255, 255, 255, 0.86) !important;
}

.iss-tour-card--featured .iss-tour-card__excerpt,
.iss-tour-card--featured .wp-block-post-excerpt,
.iss-tour-card--featured .wp-block-post-excerpt p,
.iss-tour-card--featured .wp-block-post-excerpt__excerpt {
  margin: 0 !important;
  max-width: 38ch;
  color: rgba(255, 255, 255, 0.82) !important;
  font-size: 1rem;
  line-height: 1.6;
}

.iss-tour-card--featured .iss-tour-card__actions {
  margin-top: 0.25rem;
}

.iss-tour-card--featured > .iss-tour-card__media,
.iss-tour-card--featured > .wp-block-post-featured-image,
.iss-tour-card--featured > figure.wp-block-post-featured-image {
  display: block;
  margin: 0 !important;
  min-height: 100%;
  height: 100%;
  background: var(--site-color-surface);
  line-height: 0;
}

.iss-tour-card--featured > .iss-tour-card__media a,
.iss-tour-card--featured > .wp-block-post-featured-image a,
.iss-tour-card--featured > figure.wp-block-post-featured-image a {
  display: block;
  width: 100%;
  height: 100%;
}

.iss-tour-card--featured > .iss-tour-card__media img,
.iss-tour-card--featured > .wp-block-post-featured-image img,
.iss-tour-card--featured > figure.wp-block-post-featured-image img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.iss-tour-card--featured .wp-block-read-more,
.iss-tour-card--featured .iss-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-height: 2.5rem;
  padding: 0.58rem 1rem;
  border: 1px solid rgba(255, 255, 255, 0.78);
  border-radius: 0.35rem;
  background: transparent;
  color: #fff;
  text-decoration: none;
  font-size: 0.92rem;
  font-weight: 600;
  line-height: 1.2;
  transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
}

.iss-tour-card--featured .wp-block-read-more:hover,
.iss-tour-card--featured .iss-button:hover {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.95);
  color: #fff;
  transform: translateY(-1px);
}

/* ---------------------------------------------------------------------
   REGULAR TOUR GRID
   --------------------------------------------------------------------- */

.iss-tour-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.5rem;
  align-items: stretch;
}

.iss-tour-grid > .wp-block-post,
.iss-tour-grid > li {
  min-width: 0;
  margin: 0;
}

.iss-tour-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
  border: 1px solid var(--site-color-border);
  border-radius: 1rem;
  background: var(--site-color-bg);
  box-shadow: 0 6px 18px rgba(30, 26, 30, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.iss-tour-card:hover {
  transform: translateY(-2px);
  border-color: color-mix(in srgb, var(--site-color-border) 68%, var(--site-color-text) 32%);
  box-shadow: 0 10px 26px rgba(30, 26, 30, 0.08);
}

.iss-tour-card__media,
.iss-tour-card .wp-block-post-featured-image,
.iss-tour-card figure.wp-block-post-featured-image {
  display: block;
  margin: 0 !important;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--site-color-surface);
  line-height: 0;
}

.iss-tour-card .wp-block-post-featured-image a,
.iss-tour-card__media a {
  display: block;
  width: 100%;
  height: 100%;
}

.iss-tour-card .wp-block-post-featured-image img,
.iss-tour-card__media img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.28s ease;
}

.iss-tour-card:hover .wp-block-post-featured-image img,
.iss-tour-card:hover .iss-tour-card__media img {
  transform: scale(1.02);
}

.iss-tour-card__body {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: 0.85rem;
  padding: 1rem 1rem 1.15rem;
  min-width: 0;
}

.iss-tour-card__body > * {
  margin-top: 0;
  margin-bottom: 0;
}

.iss-tour-card__title,
.iss-tour-card .wp-block-post-title {
  margin: 0 !important;
  color: var(--site-color-text);
  font-size: 1.2rem;
  line-height: 1.18;
  letter-spacing: -0.01em;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: calc(1.18em * 2);
}

.iss-tour-card__title a,
.iss-tour-card .wp-block-post-title a {
  color: inherit;
  text-decoration: none;
}

.iss-tour-card__title a:hover,
.iss-tour-card .wp-block-post-title a:hover {
  color: var(--site-color-accent);
}

.iss-tour-card__excerpt,
.iss-tour-card .wp-block-post-excerpt,
.iss-tour-card .wp-block-post-excerpt p,
.iss-tour-card .wp-block-post-excerpt__excerpt {
  margin: 0 !important;
  color: var(--site-color-text-muted);
  font-size: 0.98rem;
  line-height: 1.5;
}

.iss-tour-card__excerpt,
.iss-tour-card .wp-block-post-excerpt__excerpt {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  min-height: calc(1.5em * 3);
}

.iss-tour-card__actions {
  margin-top: auto;
  padding-top: 0.15rem;
}

.iss-tour-card .wp-block-read-more,
.iss-tour-card .iss-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-height: 2.2rem;
  padding: 0.48rem 0.9rem;
  border-radius: 999px;
  background: transparent;
  color: var(--site-color-accent);
  border: 1px solid var(--site-color-accent);
  text-decoration: none;
  font-size: 0.88rem;
  font-weight: 600;
  line-height: 1.2;
  transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.iss-tour-card .wp-block-read-more:hover,
.iss-tour-card .iss-button:hover {
  background: var(--site-color-accent);
  color: var(--site-color-text-inverse);
  transform: translateY(-1px);
}

.iss-tour-section--steel .iss-tour-card--featured .iss-tour-card__body {
  background: var(--site-color-accent-2);
}

/* ---------------------------------------------------------------------
   QUERY LOOP ADAPTER
   --------------------------------------------------------------------- */

.iss-tour-query {
  width: 100%;
}

.iss-tour-query > .wp-block-post-template {
  list-style: none;
  margin: 0 !important;
  padding: 0 !important;
}

.iss-tour-query.iss-tour-query--grid > .wp-block-post-template {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 1.5rem !important;
}

.iss-tour-query.iss-tour-query--grid > .wp-block-post-template > li {
  margin: 0 !important;
  min-width: 0;
  height: 100%;
}

/* ---------------------------------------------------------------------
   RESPONSIVE BEHAVIOUR
   --------------------------------------------------------------------- */

@media (max-width: 991px) {
  .iss-tour-grid,
  .iss-tour-query.iss-tour-query--grid > .wp-block-post-template {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}

@media (max-width: 960px) {
  .iss-tour-featured .wp-block-post-template > li > .iss-tour-card--featured,
  .iss-tour-card--featured {
    grid-template-columns: 1fr !important;
    min-height: auto;
  }

  .iss-tour-card--featured > .iss-tour-card__media,
  .iss-tour-card--featured > .wp-block-post-featured-image,
  .iss-tour-card--featured > figure.wp-block-post-featured-image {
    min-height: 18rem;
  }
}

@media (max-width: 767px) {
  .iss-tour-section {
    width: min(100%, calc(100% - 1.5rem));
    padding: 2rem 0 3rem;
  }

  .iss-tour-section__intro {
    margin-bottom: 2rem;
  }

  .iss-tour-section__headline {
    text-align: left;
  }

  .iss-tour-grid {
    grid-template-columns: 1fr;
  }

  .iss-tour-query.iss-tour-query--grid > .wp-block-post-template {
    display: flex !important;
    flex-wrap: nowrap !important;
    grid-template-columns: none !important;
    gap: 1rem !important;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    width: 100% !important;
    max-width: 100% !important;
    padding: 0 0.5rem 1rem !important;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .iss-tour-query.iss-tour-query--grid > .wp-block-post-template::-webkit-scrollbar {
    display: none;
  }

  .iss-tour-query.iss-tour-query--grid > .wp-block-post-template > li {
    flex: 0 0 84% !important;
    width: 84% !important;
    min-width: 84% !important;
    max-width: 84% !important;
    scroll-snap-align: start;
  }

  .iss-tour-card__body {
    padding: 0.9rem 0.95rem 1rem;
  }

  .iss-tour-card__title,
  .iss-tour-card .wp-block-post-title {
    font-size: 1.14rem;
  }
}






/**Overrides*/
/* =========================================================
   FEATURED TOUR – REFINED EDITORIAL VERSION
   ========================================================= */

/* container */
.iss-tour-featured {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 2rem auto 3rem;
}

/* small kicker above */
.iss-tour-featured-kicker {
  margin: 0 0 0.75rem;
  color: var(--site-color-text-muted);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.iss-tour-featured-kicker::before {
  content: "";
  width: 2.5rem;
  height: 1px;
  background: var(--site-color-border);
}

/* card layout */
.iss-tour-card--featured {
  display: grid !important;
  grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr) !important;
  min-height: 24rem;
  background: var(--site-color-accent-2);
}

/* left panel (text) */
.iss-tour-card--featured > .iss-tour-card__body {
  display: flex !important;
  flex-direction: column;
  justify-content: center;
  gap: 1rem;
  padding: clamp(1.5rem, 2.2vw, 2.5rem);
  background: var(--site-color-accent-2);
  color: var(--site-color-text-inverse);
}

/* TITLE → accent */
.iss-tour-card--featured .wp-block-post-title,
.iss-tour-card--featured .wp-block-post-title a {
  color: var(--site-color-accent) !important;
  font-size: clamp(1.7rem, 2vw, 2.3rem);
  line-height: 1.08;
  text-decoration: none;
}

/* excerpt */
.iss-tour-card--featured .wp-block-post-excerpt,
.iss-tour-card--featured .wp-block-post-excerpt p,
.iss-tour-card--featured .wp-block-post-excerpt__excerpt {
  color: rgba(255,255,255,0.82) !important;
  font-size: 0.98rem;
  line-height: 1.55;
  max-width: 34ch;
}

/* image panel (with inner frame) */
.iss-tour-card--featured > .wp-block-post-featured-image,
.iss-tour-card--featured > figure.wp-block-post-featured-image {
  display: flex !important;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  padding: clamp(1rem, 1.8vw, 1.5rem);
  background: color-mix(in srgb, var(--site-color-accent-2) 18%, var(--site-color-bg));
  height: 100%;
}

/* link wrapper */
.iss-tour-card--featured > figure a,
.iss-tour-card--featured > .wp-block-post-featured-image a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

/* image behavior → NO CROP */
.iss-tour-card--featured img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* mobile */
@media (max-width: 820px) {
  .iss-tour-card--featured {
    grid-template-columns: 1fr !important;
    min-height: auto;
  }

  .iss-tour-card--featured > .wp-block-post-featured-image,
  .iss-tour-card--featured > figure.wp-block-post-featured-image {
    min-height: 18rem;
  }
}

/* =========================================================
   TOURS PAGE SECTION WRAPPERS
   ========================================================= */

.iss-section-contained {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 0 auto;
}

.iss-section-breakout {
  width: min(1440px, calc(100% - 2rem));
  margin: 0 auto;
}

.iss-tours-regular,
.iss-tours-catalog,
.iss-tours-special {
  padding: 0 0 4rem;
}

.iss-section-heading {
  max-width: 72ch;
  margin: 0 0 1.5rem;
}

.iss-section-title {
  margin: 0 0 0.5rem;
  font-size: clamp(1.7rem, 2.2vw, 2.4rem);
  line-height: 1.08;
  color: var(--site-color-text);
}

.iss-section-text {
  margin: 0;
  color: var(--site-color-text-muted);
  font-size: 1rem;
  line-height: 1.6;
}

/* =========================================================
   REGULAR TOURS: 3-CARD WIDER ROW
   ========================================================= */

.iss-tour-query--regular > .wp-block-post-template {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 1.5rem !important;
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
}

.iss-tour-query--regular > .wp-block-post-template > li {
  margin: 0 !important;
  min-width: 0;
  height: 100%;
}

/* slightly roomier than catalog cards */
.iss-tour-query--regular .iss-tour-card__body {
  padding: 1.15rem 1.15rem 1.25rem;
}

.iss-tour-query--regular .iss-tour-card .wp-block-post-title,
.iss-tour-query--regular .iss-tour-card__title {
  font-size: 1.28rem;
}

/* =========================================================
   CATALOG: 10 ITEMS IN CONTAINED GRID
   ========================================================= */

.iss-tour-query--catalog > .wp-block-post-template {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 1.5rem !important;
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
}

.iss-tour-query--catalog > .wp-block-post-template > li {
  margin: 0 !important;
  min-width: 0;
  height: 100%;
}

/* =========================================================
   SPECIAL TOUR: FEATURED / EDITORIAL BLOCK
   ========================================================= */

.iss-tour-query--special > .wp-block-post-template {
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
}

.iss-tour-query--special > .wp-block-post-template > li {
  margin: 0 !important;
}

.iss-tours-special .iss-tour-card--featured {
  display: grid !important;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr) !important;
  min-height: 22rem;
}

.iss-tours-special .iss-tour-card--featured > .iss-tour-card__body {
  padding: clamp(1.4rem, 2vw, 2.2rem);
  gap: 0.85rem;
}

.iss-tours-special .iss-tour-card--featured .wp-block-post-title,
.iss-tours-special .iss-tour-card--featured .wp-block-post-title a {
  color: color-mix(in srgb, var(--site-color-accent) 78%, white 22%) !important;
  font-size: clamp(1.6rem, 1.8vw, 2.15rem);
  line-height: 1.06;
  text-decoration: none;
  max-width: 11ch;
}

.iss-tours-special .iss-tour-card--featured .wp-block-post-excerpt,
.iss-tours-special .iss-tour-card--featured .wp-block-post-excerpt p,
.iss-tours-special .iss-tour-card--featured .wp-block-post-excerpt__excerpt {
  max-width: 32ch;
  font-size: 0.96rem;
  line-height: 1.5;
}

.iss-tours-special .iss-tour-card--featured .wp-block-post-excerpt__excerpt,
.iss-tours-special .iss-tour-card--featured .wp-block-post-excerpt p {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 7;
  overflow: hidden;
}

.iss-tours-special .iss-tour-card--featured > .wp-block-post-featured-image,
.iss-tours-special .iss-tour-card--featured > figure.wp-block-post-featured-image {
  display: flex !important;
  align-items: center;
  justify-content: center;
  margin: 0 !important;
  padding: clamp(0.75rem, 1.4vw, 1.1rem);
  background: color-mix(in srgb, var(--site-color-surface) 88%, var(--site-color-accent-2) 12%);
  height: 100%;
}

.iss-tours-special .iss-tour-card--featured > .wp-block-post-featured-image a,
.iss-tours-special .iss-tour-card--featured > figure.wp-block-post-featured-image a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.iss-tours-special .iss-tour-card--featured img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.iss-tours-special .iss-tour-card--featured .wp-block-read-more {
  margin-top: auto;
}

/* =========================================================
   RESPONSIVE
   ========================================================= */

@media (max-width: 1100px) {
  .iss-tour-query--regular > .wp-block-post-template,
  .iss-tour-query--catalog > .wp-block-post-template {
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
  }
}

@media (max-width: 820px) {
  .iss-section-breakout,
  .iss-section-contained {
    width: min(calc(100% - 1.5rem), 100%);
  }

  .iss-tour-query--regular > .wp-block-post-template,
  .iss-tour-query--catalog > .wp-block-post-template {
    display: flex !important;
    flex-wrap: nowrap !important;
    gap: 1rem !important;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    padding: 0 0.25rem 1rem !important;
    grid-template-columns: none !important;
    scrollbar-width: none;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }

  .iss-tour-query--regular > .wp-block-post-template::-webkit-scrollbar,
  .iss-tour-query--catalog > .wp-block-post-template::-webkit-scrollbar {
    display: none;
  }

  .iss-tour-query--regular > .wp-block-post-template > li,
  .iss-tour-query--catalog > .wp-block-post-template > li {
    flex: 0 0 84% !important;
    width: 84% !important;
    min-width: 84% !important;
    max-width: 84% !important;
    scroll-snap-align: start;
  }

  .iss-tours-special .iss-tour-card--featured {
    grid-template-columns: 1fr !important;
    min-height: auto;
  }

  .iss-tours-special .iss-tour-card--featured > .wp-block-post-featured-image,
  .iss-tours-special .iss-tour-card--featured > figure.wp-block-post-featured-image {
    min-height: 18rem;
  }
}

/* =========================================================
   REGULAR TOURS – REFINED 3-CARD ROW
   ========================================================= */

.iss-section-breakout.iss-tours-regular {
  width: min(1520px, calc(100% - 3rem));
  margin: 0 auto 4rem;
}

.iss-tour-query--regular > .wp-block-post-template {
  display: grid !important;
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 2rem !important;
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
  align-items: start;
}

.iss-tour-query--regular > .wp-block-post-template > li {
  margin: 0 !important;
  min-width: 0;
  height: 100%;
}

/* make regular row cards more intentional */
.iss-tour-query--regular .iss-tour-card,
.iss-tour-query--regular .wp-block-group.iss-tour-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--site-color-bg);
  border: 1px solid var(--site-color-border);
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 6px 18px rgba(30, 26, 30, 0.05);
}

/* stronger image area */
.iss-tour-query--regular .wp-block-post-featured-image,
.iss-tour-query--regular .iss-tour-card__media,
.iss-tour-query--regular figure.wp-block-post-featured-image {
  display: block;
  margin: 0 !important;
  aspect-ratio: 4 / 3;
  background: var(--site-color-surface);
  overflow: hidden;
}

.iss-tour-query--regular .wp-block-post-featured-image a,
.iss-tour-query--regular .iss-tour-card__media a {
  display: block;
  width: 100%;
  height: 100%;
}

.iss-tour-query--regular .wp-block-post-featured-image img,
.iss-tour-query--regular .iss-tour-card__media img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* card body */
.iss-tour-query--regular .iss-tour-card__body {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: 0.9rem;
  padding: 1.15rem 1.15rem 1.25rem;
}

/* title */
.iss-tour-query--regular .iss-tour-card__title,
.iss-tour-query--regular .wp-block-post-title {
  margin: 0 !important;
  font-size: 1.5rem;
  line-height: 1.12;
  color: var(--site-color-text);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: calc(1.12em * 2);
}

.iss-tour-query--regular .iss-tour-card__title a,
.iss-tour-query--regular .wp-block-post-title a {
  color: inherit;
  text-decoration: none;
}

/* excerpt: shorter and calmer */
.iss-tour-query--regular .iss-tour-card__excerpt,
.iss-tour-query--regular .wp-block-post-excerpt,
.iss-tour-query--regular .wp-block-post-excerpt p,
.iss-tour-query--regular .wp-block-post-excerpt__excerpt {
  margin: 0 !important;
  color: var(--site-color-text-muted);
  font-size: 1rem;
  line-height: 1.55;
}

.iss-tour-query--regular .wp-block-post-excerpt__excerpt,
.iss-tour-query--regular .wp-block-post-excerpt p {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  min-height: calc(1.55em * 4);
}

/* button sits at bottom */
.iss-tour-query--regular .iss-tour-card__actions,
.iss-tour-query--regular .wp-block-read-more {
  margin-top: auto;
}

.iss-tour-query--regular .wp-block-read-more,
.iss-tour-query--regular .iss-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-height: 2.3rem;
  padding: 0.5rem 0.9rem;
  border: 1px solid var(--site-color-accent);
  border-radius: 999px;
  background: transparent;
  color: var(--site-color-accent);
  text-decoration: none;
  font-size: 0.9rem;
  font-weight: 600;
  line-height: 1.2;
}

.iss-tour-query--regular .wp-block-read-more:hover,
.iss-tour-query--regular .iss-button:hover {
  background: var(--site-color-accent);
  color: var(--site-color-text-inverse);
}

.iss-section-breakout.iss-tours-regular {
  width: min(1600px, calc(100% - 3rem));
  margin: 0 auto 4rem;
}

/* heading stays readable */
.iss-tours-regular .iss-section-heading {
  max-width: 720px;
}

/* grid uses full breakout width */
.iss-tour-query--regular {
  margin-top: 1.5rem;
}
.iss-tour-query--regular > .wp-block-post-template {
  grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
  gap: 2.4rem !important;
}

.iss-tour-query--regular .wp-block-post-featured-image {
  aspect-ratio: 3 / 2;
}

.iss-section-breakout.iss-tours-regular {
  width: min(1600px, calc(100% - 3rem));
  margin-left: max(2rem, calc((100vw - 1400px) / 2));
  margin-right: auto;
}

.iss-section-text {
  max-width: 60ch;
}

/* regular section must really break out */
.iss-section-breakout.iss-tours-regular {
  width: min(1600px, calc(100% - 3rem)) !important;
  max-width: none !important;
  margin: 0 auto 4rem !important;
}

/* defeat Gutenberg constrained layout on this section */
.wp-block-group.iss-section-breakout.iss-tours-regular,
.wp-block-group.iss-section-breakout.iss-tours-regular.is-layout-constrained,
.wp-block-group.iss-section-breakout.iss-tours-regular.wp-block-group-is-layout-constrained {
  max-width: none !important;
}

/* keep only heading readable */
.iss-tours-regular > .iss-section-heading {
  max-width: 720px;
  margin: 0 0 1.5rem;
}

/* let query use full breakout width */
.iss-tours-regular > .iss-tour-query {
  width: 100%;
  max-width: none;
}

.iss-tours-regular > .iss-section-heading {
  max-width: 760px;
  margin: 0 0 1.75rem;
}

.iss-tours-regular > .iss-section-heading::before {
  
  display: block;
  margin-bottom: 0.65rem;
  color: var(--site-color-text-muted);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.iss-tours-regular .iss-section-title {
  margin: 0 0 0.45rem;
  font-size: clamp(2rem, 2.6vw, 3rem);
  line-height: 1.04;
  text-align: left;
}

.iss-tours-regular .iss-section-text {
  max-width: 54ch;
  margin: 0;
  font-size: 1rem;
  line-height: 1.55;
  text-align: left;
  color: var(--site-color-text-muted);
}
.iss-tours-regular > .iss-section-heading {
  margin-bottom: 1.25rem; /* instead of ~1.75rem */
}
.iss-tours-catalog > .iss-section-heading {
  max-width: 760px;
  margin: 0 0 1.25rem;
}

.iss-tours-catalog .iss-section-title {
  margin: 0 0 0.45rem;
  font-size: clamp(1.9rem, 2.2vw, 2.6rem);
  line-height: 1.08;
  text-align: left;
}

.iss-tours-catalog .iss-section-text {
  max-width: 56ch;
  margin: 0;
  font-size: 1rem;
  line-height: 1.55;
  color: var(--site-color-text-muted);
}

.iss-tour-query--catalog > .wp-block-post-template {
  gap: 1.75rem !important;
}

.iss-tour-query--catalog .iss-tour-card,
.iss-tour-query--catalog .wp-block-group.iss-tour-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: var(--site-color-bg);
  border: 1px solid var(--site-color-border);
  border-radius: 1rem;
  overflow: hidden;
  box-shadow: 0 4px 14px rgba(30, 26, 30, 0.04);
}

.iss-tour-query--catalog .wp-block-post-featured-image,
.iss-tour-query--catalog figure.wp-block-post-featured-image,
.iss-tour-query--catalog .iss-tour-card__media {
  aspect-ratio: 4 / 3;
  margin: 0 !important;
  overflow: hidden;
  background: var(--site-color-surface);
}

.iss-tour-query--catalog .wp-block-post-featured-image img,
.iss-tour-query--catalog figure.wp-block-post-featured-image img,
.iss-tour-query--catalog .iss-tour-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.iss-tour-query--catalog .iss-tour-card__body {
  display: flex;
  flex: 1 1 auto;
  flex-direction: column;
  gap: 0.85rem;
  padding: 1rem 1rem 1.15rem;
}

.iss-tour-query--catalog .wp-block-post-title,
.iss-tour-query--catalog .iss-tour-card__title {
  margin: 0 !important;
  font-size: 1.22rem;
  line-height: 1.16;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  min-height: calc(1.16em * 2);
}

.iss-tour-query--catalog .wp-block-post-excerpt,
.iss-tour-query--catalog .wp-block-post-excerpt p,
.iss-tour-query--catalog .wp-block-post-excerpt__excerpt {
  margin: 0 !important;
  color: var(--site-color-text-muted);
  font-size: 0.96rem;
  line-height: 1.5;
}

.iss-tour-query--catalog .wp-block-post-excerpt p,
.iss-tour-query--catalog .wp-block-post-excerpt__excerpt {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
  min-height: calc(1.5em * 4);
}

.iss-tour-query--catalog .wp-block-read-more,
.iss-tour-query--catalog .iss-button {
  margin-top: auto;
}

.iss-special-block {
  max-width: 760px;
}

.iss-special-block h3 {
  margin: 0 0 0.5rem;
  font-size: 1.4rem;
}

.iss-special-block p {
  margin: 0 0 1rem;
  color: var(--site-color-text-muted);
}

.iss-special-block ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.iss-special-block li {
  padding: 0.75rem 0;
  border-top: 1px solid var(--site-color-border);
}

.iss-special-block li:first-child {
  border-top: none;
}

/* date line */
.iss-special-block strong {
  display: block;
  font-weight: 600;
}

/* sold out */
.iss-special-block .is-sold-out {
  color: var(--wp--preset--color--accent);
  font-weight: 600;
}
.iss-tours-special > .iss-section-heading {
  max-width: 760px;
  margin: 0 0 1.25rem;
}

.iss-special-schedule {
  max-width: 860px;
  display: grid;
  gap: 0;
  border-top: 1px solid var(--site-color-border);
}

.iss-special-schedule__item {
  display: grid;
  grid-template-columns: minmax(180px, 220px) 1fr auto;
  gap: 1rem 1.25rem;
  align-items: start;
  padding: 1rem 0;
  border-bottom: 1px solid var(--site-color-border);
}

.iss-special-schedule__date {
  font-weight: 600;
  color: var(--site-color-text);
}

.iss-special-schedule__title {
  font-weight: 600;
  color: var(--site-color-text);
  line-height: 1.35;
}

.iss-special-schedule__meta {
  grid-column: 2 / 3;
  color: var(--site-color-text-muted);
  line-height: 1.5;
}

.iss-special-schedule__status {
  color: var(--site-color-accent);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.iss-special-schedule__item.is-sold-out .iss-special-schedule__title {
  opacity: 0.88;
}

.iss-button--small {
  min-height: 2.2rem;
  padding: 0.45rem 0.85rem;
  font-size: 0.88rem;
}

@media (max-width: 820px) {
  .iss-special-schedule__item {
    grid-template-columns: 1fr;
  }

  .iss-special-schedule__meta {
    grid-column: auto;
  }
}

.iss-special-schedule {
  max-width: 860px;
  border-top: 1px solid var(--site-color-border);
}

.iss-special-schedule__item {
  display: grid;
  grid-template-columns: 240px minmax(0, 1fr) 140px;
  column-gap: 1.5rem;
  align-items: start;
  padding: 1rem 0;
  border-bottom: 1px solid var(--site-color-border);
}

.iss-special-schedule__date,
.iss-special-schedule__title,
.iss-special-schedule__meta,
.iss-special-schedule__status {
  margin: 0;
}

.iss-special-schedule__date {
  font-weight: 600;
  line-height: 1.35;
}

.iss-special-schedule__text {
  display: grid;
  gap: 0.35rem;
  min-width: 0;
}

.iss-special-schedule__title {
  font-weight: 600;
  line-height: 1.35;
}

.iss-special-schedule__meta {
  color: var(--site-color-text-muted);
  line-height: 1.45;
}

.iss-special-schedule__action {
  display: flex;
  justify-content: flex-end;
  align-items: start;
}

.iss-special-schedule__status {
  color: var(--site-color-accent);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-align: right;
}

.iss-special-schedule__item.is-sold-out .iss-special-schedule__title {
  opacity: 0.92;
}

/* keep one typographic voice */
.iss-special-schedule__date,
.iss-special-schedule__title {
  font-style: normal;
}

/* mobile */
@media (max-width: 820px) {
  .iss-special-schedule__item {
    grid-template-columns: 1fr;
    row-gap: 0.6rem;
  }

  .iss-special-schedule__action {
    justify-content: flex-start;
  }

  .iss-special-schedule__status {
    text-align: left;
  }
}
/* =========================================
   FULL-WIDTH SECTION BANDS
   ========================================= */

.iss-band {
  position: relative;
  padding: var(--site-space-7) 0;
}

.iss-band::before {
  content: "";
  position: absolute;
  inset: 0;
  left: 50%;
  width: 100vw;
  transform: translateX(-50%);
  z-index: 0;
}

/* variants using your palette */
.iss-band--soft::before {
  background: var(--site-color-surface);
}

.iss-band--steel::before {
  background: var(--site-color-accent-2);
}

/* content stays aligned */
.iss-band > * {
  position: relative;
  z-index: 1;
}

.iss-tours-special {
  padding: 3.5rem 0 4rem;
}

/* =========================================================
   FOOTER
   ========================================================= */

.iss-footer {
  background: var(--site-color-surface);
  border-top: 1px solid var(--site-color-border);
}

.iss-footer__inner {
  width: min(var(--site-width-wide), calc(100% - 2rem));
  margin: 0 auto;
  padding: var(--site-space-7) 0 var(--site-space-8);
  display: grid;
  grid-template-columns: 1.5fr 1.1fr 0.95fr 1.15fr;
  gap: clamp(1.5rem, 3vw, 3rem);
  align-items: start;
}

.iss-footer__brand,
.iss-footer__contact,
.iss-footer__hours,
.iss-footer__nav,
.iss-footer__legal {
  min-width: 0;
}

.iss-footer__brand {
  display: grid;
  gap: 1rem;
  align-content: start;
}

.iss-footer__tagline {
  margin: 0;
  max-width: 22ch;
  color: var(--site-color-text);
  font-size: 0.98rem;
  line-height: 1.5;
}

.iss-footer__social {
  margin: 0;
}

.iss-footer__meta {
  margin: 0.25rem 0 0;
  color: var(--site-color-text-muted);
}

.iss-footer__heading {
  margin: 0 0 0.9rem;
  color: var(--site-color-text);
  font-size: 1.05rem;
  line-height: 1.2;
  letter-spacing: -0.01em;
}

.iss-footer__contact p,
.iss-footer__hours p {
  margin: 0 0 1rem;
  color: var(--site-color-text);
  line-height: 1.65;
}

.iss-footer__label {
  display: inline-block;
  margin-bottom: 0.15rem;
  color: var(--site-color-text-muted);
  font-size: 0.92rem;
  font-weight: 600;
}

.iss-footer__nav-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  align-items: start;
}

.iss-footer__menu {
  gap: 0.55rem;
}

.iss-footer__menu .wp-block-navigation-item {
  margin: 0;
}

.iss-footer__menu .wp-block-navigation-item__content,
.iss-footer__menu .wp-block-pages-list__item__link,
.iss-footer__contact a {
  color: var(--site-color-text);
  text-decoration: none;
}

.iss-footer__menu .wp-block-navigation-item__content:hover,
.iss-footer__menu .wp-block-pages-list__item__link:hover,
.iss-footer__contact a:hover {
  color: var(--site-color-accent);
}

.iss-footer__legal .wp-block-navigation-item__content,
.iss-footer__legal .wp-block-pages-list__item__link {
  color: var(--site-color-text-muted);
}

.iss-footer .wp-block-site-logo img {
  display: block;
  width: auto;
  max-height: 72px;
}

.iss-footer .wp-block-social-links .wp-social-link a {
  transition: transform 0.2s ease;
}

.iss-footer .wp-block-social-links .wp-social-link a:hover {
  transform: translateY(-1px);
}

/* =========================================================
   RESPONSIVE
   ========================================================= */

@media (max-width: 1000px) {
  .iss-footer__inner {
    grid-template-columns: 1.3fr 1fr 1fr;
  }

  .iss-footer__nav-wrap {
    grid-column: 1 / -1;
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 760px) {
  .iss-footer__inner {
    width: min(calc(100% - 1.5rem), var(--site-width-wide));
    grid-template-columns: 1fr;
    gap: 2rem;
    padding: var(--site-space-6) 0;
  }

  .iss-footer__nav-wrap {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .iss-footer__tagline {
    max-width: 100%;
  }
}