{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "industriesalon/timeline",
  "title": "Timeline",
  "category": "widgets",
  "icon": "schedule",
  "description": "Server-rendered timeline from calendar items.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": { "type": "string", "default": "" },
    "intro": { "type": "string", "default": "" },
    "limit": { "type": "number", "default": 50 },
    "group": { "type": "string", "default": "" },
    "yearGrouping": { "type": "boolean", "default": true }
  },
  "editorScript": "file:./index.js"
}

