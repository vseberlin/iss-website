{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "industriesalon/timeline-sections",
  "title": "Timeline Sections",
  "category": "widgets",
  "icon": "index-card",
  "description": "Server-rendered timeline split into next / monthly / archive sections.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": { "type": "string", "default": "" },
    "intro": { "type": "string", "default": "" },
    "group": { "type": "string", "default": "" },

    "nextTitle": { "type": "string", "default": "Was kommt als Nächstes" },
    "nextLimit": { "type": "number", "default": 4 },

    "monthlyTitle": { "type": "string", "default": "Monatsübersicht" },
    "monthlyLimit": { "type": "number", "default": 80 },

    "archiveTitle": { "type": "string", "default": "Archiv" },
    "archiveLimit": { "type": "number", "default": 250 }
  },
  "editorScript": "file:./index.js"
}

