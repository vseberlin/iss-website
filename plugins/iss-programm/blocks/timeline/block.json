{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "industriesalon/timeline",
  "title": "Timeline",
  "category": "widgets",
  "icon": "schedule",
  "description": "Server-rendered timeline from calendar items.",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": { "type": "string", "default": "" },
    "kicker": { "type": "string", "default": "" },
    "showTitle": { "type": "boolean", "default": true },
    "showKicker": { "type": "boolean", "default": false },
    "intro": { "type": "string", "default": "" },
    "limit": { "type": "number", "default": 50 },
    "group": { "type": "string", "default": "" },
    "yearGrouping": { "type": "boolean", "default": true },
    "showDetailsButton": { "type": "boolean", "default": true },
    "showRecommendButton": { "type": "boolean", "default": true },
    "showTicketsButton": { "type": "boolean", "default": true },
    "detailsButtonText": { "type": "string", "default": "" },
    "recommendButtonText": { "type": "string", "default": "" },
    "ticketsButtonText": { "type": "string", "default": "" },
    "detailsButtonUrl": { "type": "string", "default": "" },
    "recommendButtonUrl": { "type": "string", "default": "" },
    "ticketsButtonUrl": { "type": "string", "default": "" },
    "showBottomButton": { "type": "boolean", "default": false },
    "bottomButtonText": { "type": "string", "default": "" },
    "bottomButtonUrl": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js"
}
